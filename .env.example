# ─── Required for Vercel deployment ────────────────────────────────────────────
# All variables below must be added in the Vercel project dashboard under
# Settings → Environment Variables.  .env.local is gitignored and is NOT
# deployed automatically.

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/life-lessons

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=https://your-production-domain.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-production-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://your-production-domain.vercel.app

# Google OAuth (configure redirect URI in Google Console for production domain)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (use live keys for production, test keys for preview/development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: backend server URL (used by next.config.mjs rewrites)
SERVER_URL=https://your-backend-server.com
